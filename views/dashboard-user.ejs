<div class="max-w-screen-lg mx-auto">
    <header class="flex flex-col gap-4 mb-8">
        <div class="flex flex-col gap-2">
            <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Dashboard Pengguna</h1>
            <p class="text-muted-foreground">Selamat datang di sistem peminjaman ruangan, <b><%= user.name %></b>.</p>
        </div>
    </header>

    <!-- FITUR 10 - Statistik Penggunaan Ruangan (Fazira) -->
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 2rem;">
    <div class="card p-3">
        <header>
            <p class="text-xs text-muted-foreground">Total Peminjaman</p>
            <h2 class="text-2xl font-bold"><%= stats.total %></h2>
        </header>
    </div>
    <div class="card p-3">
        <header>
            <p class="text-xs text-muted-foreground">Menunggu</p>
            <h2 class="text-2xl font-bold text-orange-500"><%= stats.menunggu %></h2>
        </header>
    </div>
    <div class="card p-3">
        <header>
            <p class="text-xs text-muted-foreground">Disetujui</p>
            <h2 class="text-2xl font-bold text-green-500"><%= stats.disetujui %></h2>
        </header>
    </div>
    <div class="card p-3">
        <header>
            <p class="text-xs text-muted-foreground">Selesai</p>
            <h2 class="text-2xl font-bold text-blue-500"><%= stats.selesai %></h2>
        </header>
    </div>
</div>