<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/assets/styles.css" />
</head>

<body class="bg-background">
    <div class="flex min-h-svh flex-col p-6 md:p-10 lg:px-32">
        <div class="w-full max-w-4xl mx-auto">
            <div class="flex flex-col gap-6">
                <div
                    class="flex flex-col gap-6 rounded-xl border bg-card text-card-foreground shadow-sm overflow-hidden p-0">

                    <form id="bookingForm" class="p-6 md:p-8">
                        <div class="flex flex-col gap-7">
                            <div class="flex flex-col gap-2">
                                <h1 class="text-2xl font-bold">Tambah Peminjaman Ruangan</h1>
                                <p class="text-muted-foreground">Silakan isi formulir di bawah untuk mengajukan
                                    pemakaian ruangan.</p>
                            </div>

                            <div id="notif" style="display:none;" class="p-3 rounded-md text-sm font-medium"></div>

                            <div class="group/field flex w-full gap-3 flex-col">
                                <label class="text-sm font-medium">Pilih Ruangan</label>
                                <select name="room_id" required
                                    class="h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm outline-none focus:ring-2 focus:ring-ring">
                                    <option value="" disabled selected>-- Pilih Ruangan --</option>
                                    <% if (rooms && rooms.length> 0) { rooms.forEach(function(room) { %>
                                        <option value="<%= room.id %>">
                                            <%= room.name %>
                                        </option>
                                        <% }); } %>
                                </select>
                            </div>

                            <div class="group/field flex w-full gap-3 flex-col">
                                <label class="text-sm font-medium">Tanggal Peminjaman</label>
                                <input type="date" name="tanggal" required
                                    class="h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm outline-none focus:ring-2 focus:ring-ring">
                            </div>

                            <div class="grid grid-cols-2 gap-4">
                                <div class="group/field flex w-full gap-3 flex-col">
                                    <label class="text-sm font-medium">Jam Mulai</label>
                                    <input type="time" name="jam_mulai" required
                                        class="h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm outline-none focus:ring-2 focus:ring-ring">
                                </div>
                                <div class="group/field flex w-full gap-3 flex-col">
                                    <label class="text-sm font-medium">Jam Selesai</label>
                                    <input type="time" name="jam_selesai" required
                                        class="h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm outline-none focus:ring-2 focus:ring-ring">
                                </div>
                            </div>

                            <div class="group/field flex w-full gap-3 flex-col">
                                <label class="text-sm font-medium">Keperluan</label>
                                <textarea name="purpose" rows="3" required
                                    class="w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-ring"></textarea>
                            </div>

                            <div class="flex gap-4 mt-2">
                                <button type="submit" id="submitBtn"
                                    class="bg-primary text-primary-foreground h-9 px-4 rounded-md text-sm font-medium hover:bg-primary/90">
                                    Ajukan Peminjaman
                                </button>
                                <a href="/bookings"
                                    class="border border-input bg-background hover:bg-accent h-9 px-4 flex items-center rounded-md text-sm font-medium">Batal</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('bookingForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const notif = document.getElementById('notif');
            const submitBtn = document.getElementById('submitBtn');

            // Ambil data form
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());

            submitBtn.disabled = true;
            submitBtn.innerText = "Mengirim...";

            try {
                const response = await fetch('/bookings/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                notif.style.display = 'block';
                if (response.status === 200) {
                    notif.className = "p-3 rounded-md text-sm font-medium bg-green-100 text-green-800";
                    notif.innerText = result.message;
                    setTimeout(() => window.location.href = '/bookings', 1500);
                } else {
                    notif.className = "p-3 rounded-md text-sm font-medium bg-red-100 text-red-800";
                    notif.innerText = result.error;
                    submitBtn.disabled = false;
                    submitBtn.innerText = "Ajukan Peminjaman";
                }
            } catch (err) {
                notif.style.display = 'block';
                notif.className = "p-3 rounded-md text-sm font-medium bg-red-100 text-red-800";
                notif.innerText = "Terjadi kesalahan koneksi.";
                submitBtn.disabled = false;
                submitBtn.innerText = "Ajukan Peminjaman";
            }
        });
    </script>
</body>

</html>