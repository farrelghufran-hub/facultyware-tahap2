<div class="flex flex-col gap-6">
    <div class="flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold">
                <%= title %>
            </h1>
            <p class="text-muted-foreground text-sm mt-1">
                <%= user.role==='penanggung_jawab' ? 'Kelola seluruh pengajuan peminjaman mahasiswa.'
                    : 'Pantau status pengajuan peminjaman ruangan Anda.' %>
            </p>
        </div>
        <% if (user.role !=='penanggung_jawab' ) { %>
            <a href="/bookings/add"
                class="inline-flex items-center justify-center gap-2 rounded-md text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 h-9 px-4 py-2">
                + Ajukan Ruangan
            </a>
            <% } %>
    </div>

    <div data-slot="card" class="rounded-xl border bg-card text-card-foreground shadow-sm overflow-hidden">
        <div class="relative w-full overflow-auto">
            <table class="w-full caption-bottom text-sm">
                <thead class="[&_tr]:border-b">
                    <tr class="border-b bg-muted/50">
                        <th class="h-10 px-4 text-left font-bold text-muted-foreground">No.</th>

                        <% if (user.role==='penanggung_jawab' ) { %>
                            <th class="h-10 px-4 text-left font-bold text-muted-foreground">Peminjam</th>
                            <% } %>

                                <th class="h-10 px-4 text-left font-bold text-muted-foreground">Ruangan</th>
                                <th class="h-10 px-4 text-left font-bold text-muted-foreground">Jadwal (WIB)</th>
                                <th class="h-10 px-4 text-left font-bold text-muted-foreground">Keperluan</th>
                                <th class="h-10 px-4 text-left font-bold text-muted-foreground">Status</th>

                                <th class="h-10 px-4 text-center font-bold text-muted-foreground">Aksi</th>
                    </tr>
                </thead>
                <tbody class="[&_tr:last-child]:border-0">
                    <% if (bookings && bookings.length> 0) { %>
                        <% bookings.forEach(function(booking, index) { %>
                            <tr class="border-b transition-colors hover:bg-muted/50">
                                <td class="p-4 align-middle">
                                    <%= index + 1 %>
                                </td>

                                <% if (user.role==='penanggung_jawab' ) { %>
                                    <td class="p-4 align-middle font-medium">
                                        <%= booking.borrower_name %>
                                    </td>
                                    <% } %>

                                        <td class="p-4 align-middle">
                                            <%= booking.room_name %>
                                        </td>
                                        <td class="p-4 align-middle text-muted-foreground">
                                            <%= new Date(booking.start_time).toLocaleString('id-ID', {dateStyle: 'short'
                                                , timeStyle: 'short' }) %> <br> s.d <br>
                                                <%= new Date(booking.end_time).toLocaleString('id-ID',
                                                    {dateStyle: 'short' , timeStyle: 'short' }) %>
                                        </td>
                                        <td class="p-4 align-middle">
                                            <%= booking.purpose %>
                                        </td>

                                        <td class="p-4 align-middle">
                                            <% if (booking.status==='approved' ) { %>
                                                <span
                                                    class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold bg-green-500/10 text-green-600 border-green-500/20">DISETUJUI</span>
                                                <% } else if (booking.status==='rejected' ) { %>
                                                    <span
                                                        class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold bg-red-500/10 text-red-600 border-red-500/20">DITOLAK</span>
                                                    <% } else { %>
                                                        <span
                                                            class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold bg-orange-500/10 text-orange-600 border-orange-500/20">MENUNGGU</span>
                                                        <% } %>
                                        </td>

                                        <td class="p-4 align-middle text-center">
                                            <div class="flex gap-2 justify-center">
                                                <% if (user.role==='penanggung_jawab' && booking.status==='requested' )
                                                    { %>
                                                    <form action="/bookings/<%= booking.id %>/action" method="POST">
                                                        <input type="hidden" name="action_status" value="approved">
                                                        <button type="submit"
                                                            class="inline-flex h-8 items-center justify-center rounded-md border border-green-500/30 bg-green-500/10 px-3 text-xs font-medium text-green-600 hover:bg-green-500 hover:text-white transition-colors">ACC</button>
                                                    </form>
                                                    <form action="/bookings/<%= booking.id %>/action" method="POST">
                                                        <input type="hidden" name="action_status" value="rejected">
                                                        <button type="submit"
                                                            class="inline-flex h-8 items-center justify-center rounded-md border border-red-500/30 bg-red-500/10 px-3 text-xs font-medium text-red-600 hover:bg-red-500 hover:text-white transition-colors">Tolak</button>
                                                    </form>

                                                    <% } else if (user.role !=='penanggung_jawab' &&
                                                        (booking.status==='approved' || booking.status==='requested' ))
                                                        { %>
                                                        <a href="/bookings/<%= booking.id %>/download" target="_blank"
                                                            class="inline-flex h-8 items-center justify-center rounded-md border border-blue-500/30 bg-blue-500/10 px-3 text-xs font-medium text-blue-600 hover:bg-blue-500 hover:text-white transition-colors">
                                                            Unduh PDF
                                                        </a>
                                                        <% } else { %>
                                                            <span class="text-xs text-muted-foreground">-</span>
                                                            <% } %>
                                            </div>
                                        </td>
                            </tr>
                            <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" class="p-4 align-middle text-center text-muted-foreground py-8">
                                            Belum ada data peminjaman yang diajukan.
                                        </td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>