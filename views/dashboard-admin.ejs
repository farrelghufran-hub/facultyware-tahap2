<div class="max-w-screen-lg mx-auto">
    <header class="flex flex-col gap-4 mb-8">
        <div class="flex flex-col gap-2">
            <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Dashboard Penanggung Jawab</h1>
            <p class="text-muted-foreground">Selamat bertugas memverifikasi peminjaman, Bapak/Ibu <b><%= user.name %></b>.</p>
        </div>
    </header>

    <!-- FITUR 10 - Statistik (Fazira) -->
    <div class="grid grid-cols-3 gap-3 mb-8">
        <div class="card p-3">
            <header>
                <p class="text-xs text-muted-foreground">Total</p>
                <h2 class="text-2xl font-bold"><%= stats.total %></h2>
            </header>
        </div>
        <div class="card p-3">
            <header>
                <p class="text-xs text-muted-foreground">Menunggu</p>
                <h2 class="text-2xl font-bold text-orange-500"><%= stats.menunggu %></h2>
            </header>
        </div>
        <div class="card p-3">
            <header>
                <p class="text-xs text-muted-foreground">Disetujui</p>
                <h2 class="text-2xl font-bold text-green-500"><%= stats.disetujui %></h2>
            </header>
        </div>
        <div class="card p-3">
            <header>
                <p class="text-xs text-muted-foreground">Selesai</p>
                <h2 class="text-2xl font-bold text-blue-500"><%= stats.selesai %></h2>
            </header>
        </div>
        <div class="card p-3">
            <header>
                <p class="text-xs text-muted-foreground">Ditolak</p>
                <h2 class="text-2xl font-bold text-red-500"><%= stats.ditolak %></h2>
            </header>
        </div>
    </div>

    <!-- Menu Utama -->
    <div class="grid grid-cols-1 gap-4">
        <a href="/bookings" class="card hover:border-primary transition-colors cursor-pointer">
            <header>
                <h2 class="font-bold text-lg">Verifikasi Pengajuan Ruangan</h2>
                <p>Lihat semua pengajuan, lalu tentukan Setujui atau Tolak.</p>
            </header>
        </a>
    </div>
</div>

